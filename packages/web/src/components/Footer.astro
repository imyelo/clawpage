---
import { getProjectConfig } from '../lib/config.js'
import { version } from '../../package.json'
import { parseInlineUiMarkdown } from '../lib/ui-markdown.js'

const config = await getProjectConfig()
let footerMarkdown = config.template?.options?.footer

let customFooter = ''
if (typeof footerMarkdown === 'string' && footerMarkdown.trim()) {
  customFooter = parseInlineUiMarkdown(footerMarkdown)
}
---

<footer class="layout-footer">
  <p class="layout-footer-text">
    // generated by <a href="https://github.com/imyelo/openclaw-chats-share" class="layout-footer-link">chats-share</a> <span>@ v{version}</span>
    {!!customFooter && (
      <>
        <span style="margin: 0 0.5rem; color: var(--border);">◆</span>
        <span set:html={customFooter} />
      </>
    )}
  </p>
</footer>

<style>
  .layout-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    text-align: left;
  }

  .layout-footer-text {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  :global(.layout-footer-link) {
    color: var(--accent-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  :global(.layout-footer-link:hover) {
    color: var(--accent);
  }
</style>
