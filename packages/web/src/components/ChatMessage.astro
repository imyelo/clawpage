---
import { Marked } from 'marked'
import markedShiki from 'marked-shiki'
import MessageHeader from './MessageHeader.astro'
import { getHighlighter } from '../lib/highlighter'

interface Props {
  author: string
  timestamp: string
  content: string
  isUser?: boolean
  isFirstInGroup?: boolean
  isLastInGroup?: boolean
  avatarColorIndex?: number
}

const {
  author,
  timestamp,
  content,
  isUser,
  isFirstInGroup = true,
  isLastInGroup = true,
  avatarColorIndex,
} = Astro.props

const authorLower = author.toLowerCase()
const isAgent = isUser !== undefined
  ? !isUser
  : authorLower.includes('agent') || authorLower.includes('assistant')

/**
 * Pre-process markdown to fix nested code fences.
 *
 * CommonMark closes a fenced block on the first line that has ≥N same
 * backticks with nothing else, so content like:
 *
 *   ```markdown
 *   ...
 *   ```bash
 *   cmd
 *   ```          ← marked closes the OUTER fence here
 *   ...
 *   ```          ← outer closer, but marked never reaches it
 *
 * We detect this by doing a balanced-fence parse to find the intended
 * closer, then checking whether the body contains any line that would
 * prematurely close the outer fence.  If so, we upgrade both the opener
 * and the intended closer to use one extra backtick.
 */
function fixNestedFences(input: string): string {
  const lines = input.split('\n')
  const result = [...lines]
  let i = 0

  while (i < lines.length) {
    const openerMatch = lines[i].match(/^(`{3,}|~{3,})(\S*)$/)
    if (!openerMatch) { i++; continue }

    const outerChar = openerMatch[1][0] as '`' | '~'
    const outerLen  = openerMatch[1].length
    const lang      = openerMatch[2]

    // Walk forward with balanced inner-fence tracking to find the
    // INTENDED closer (not the first ``` marked would grab).
    let innerDepth = 0
    let innerChar  = ''
    let innerLen   = 0
    const bodyIndices: number[] = []
    let trueCloserIdx = -1
    let j = i + 1

    while (j < lines.length) {
      const line = lines[j]

      if (innerDepth === 0) {
        // Valid outer closer: only backticks/tildes, same char, same/more count
        const closerMatch = line.match(/^(`{3,}|~{3,})\s*$/)
        if (closerMatch && closerMatch[1][0] === outerChar && closerMatch[1].length >= outerLen) {
          trueCloserIdx = j
          break
        }
        // Inner fence opener: backticks/tildes followed by a language tag
        const innerOpener = line.match(/^(`{3,}|~{3,})(\S+)$/)
        if (innerOpener) {
          innerDepth = 1
          innerChar  = innerOpener[1][0]
          innerLen   = innerOpener[1].length
        }
      } else {
        // Inside an inner fence — look for its closer
        const innerCloser = line.match(/^(`{3,}|~{3,})\s*$/)
        if (innerCloser && innerCloser[1][0] === innerChar && innerCloser[1].length >= innerLen) {
          innerDepth = 0
        }
      }

      bodyIndices.push(j)
      j++
    }

    if (trueCloserIdx !== -1) {
      // Find the longest backtick-only line in the body — if it is ≥ outerLen,
      // marked would close the outer fence there prematurely.
      const bodyLines = bodyIndices.map(idx => lines[idx])
      let maxConflictLen = 0
      for (const l of bodyLines) {
        const m = l.match(/^(`+)\s*$/)
        if (m && m[1].length >= outerLen) maxConflictLen = Math.max(maxConflictLen, m[1].length)
      }
      if (maxConflictLen > 0) {
        const upgraded = outerChar.repeat(maxConflictLen + 1)
        result[i]            = upgraded + lang
        result[trueCloserIdx] = upgraded
      }
    }

    i = (trueCloserIdx >= 0 ? trueCloserIdx : i) + 1
  }

  return result.join('\n')
}

// Use a fresh Marked instance to avoid inheriting any globally-registered
// extensions (e.g. the link renderer registered in Footer.astro).
const highlighter = await getHighlighter()
const md = new Marked()
md.use(markedShiki({
  highlight(code, lang) {
    const loaded = highlighter.getLoadedLanguages()
    const validLang = (lang && loaded.includes(lang)) ? lang : 'text'
    return highlighter.codeToHtml(code, {
      lang: validLang,
      theme: 'vitesse-dark'
    })
  }
}))

const htmlContent = await md.parse(content)
---

<article
  class:list={[
    'chat-message',
    isLastInGroup ? 'last-in-group' : 'not-last-in-group',
    !isFirstInGroup && 'not-first-in-group',
  ]}
  data-author={author}
>
  <MessageHeader
    author={author}
    timestamp={timestamp}
    isFirstInGroup={isFirstInGroup}
    avatarColorIndex={avatarColorIndex}
  />
  <div class:list={['message-body', isAgent ? 'body-agent' : 'body-user']}>
    <!-- set:html content is trusted (session logs); :global() selectors below
         target the injected elements that won't carry Astro's scoping attr. -->
    <div class="message-content" set:html={htmlContent} />
  </div>
</article>

<style>
  /* ── Layout ─────────────────────────────────── */

  .chat-message {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Regular messages always carry the full 1.5rem gap below them — the loose
     spacing marks the end of a speech unit regardless of what follows.
     No extra top margin is needed: the gap comes from the previous
     element's margin-bottom, not from the receiver's margin-top. */
  .last-in-group      { margin-bottom: 1.5rem; }
  .not-last-in-group  { margin-bottom: 1.5rem; }
  .not-first-in-group { margin-top: 0; }

  .message-body {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    border-radius: 2px;
    padding: 1rem 1.5rem;
    color: var(--text-primary);
    font-family: var(--font-sans);
  }

  .body-agent {
    background-color: var(--assistant-msg-bg);
    border: 1px solid var(--assistant-msg-border);
  }

  .body-user {
    background-color: var(--user-msg-bg);
    border: 1px solid var(--user-msg-border);
  }

  .message-content {
    font-size: 14.5px;
    line-height: 1.75;
  }

  /* ── Prose (markdown rendered via set:html) ── */

  .message-content :global(h1),
  .message-content :global(h2),
  .message-content :global(h3),
  .message-content :global(h4),
  .message-content :global(h5),
  .message-content :global(h6) {
    margin-top: 1em;
    margin-bottom: 0.5em;
    font-weight: 600;
    font-family: var(--font-serif);
    color: var(--text-primary);
  }

  .message-content :global(h1) { font-size: 1.5em; }
  .message-content :global(h2) { font-size: 1.25em; }
  .message-content :global(h3) { font-size: 1.1em; }

  .message-content :global(p) {
    margin-top: 1em;
    margin-bottom: 1em;
    color: #a8a7a5;
  }

  .message-content :global(ul),
  .message-content :global(ol) {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
    padding-left: 1.5em;
    color: #a8a7a5;
  }

  .message-content :global(li) {
    margin-top: 0.375em;
    margin-bottom: 0.375em;
    color: #a8a7a5;
  }

  .message-content :global(strong),
  .message-content :global(b) {
    color: #ffffff;
    font-weight: 700;
  }

  .message-content :global(a) {
    color: var(--accent);
    text-decoration: none;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .message-content :global(a:hover) {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .message-content :global(code) {
    color: var(--accent);
    background: var(--bg-tertiary);
    padding: 0.125em 0.375em;
    border-radius: 2px;
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  .message-content :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1em;
    overflow-x: auto;
    margin-top: 0.75em;
    margin-bottom: 0.75em;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  /* shiki wraps output in <pre class="shiki"> — override background to keep design consistent with inline styles. */
  .message-content :global(pre.shiki) {
    background-color: var(--bg-secondary) !important;
  }

  .message-content :global(pre::-webkit-scrollbar) {
    height: 6px;
    width: 6px;
  }

  .message-content :global(pre::-webkit-scrollbar-track) {
    background: transparent;
  }

  .message-content :global(pre::-webkit-scrollbar-thumb) {
    background: var(--border);
    border-radius: 3px;
  }

  .message-content :global(pre::-webkit-scrollbar-thumb:hover) {
    background: var(--text-muted);
  }

  .message-content :global(pre code) {
    background: transparent;
    padding: 0;
    border-radius: 0;
    color: var(--text-primary);
    font-size: 0.875em;
  }

  .message-content :global(blockquote) {
    margin: 1em 0;
    padding: 0.75em 1em;
    border-left: 3px solid var(--accent);
    color: var(--text-secondary);
    font-style: normal;
    background: var(--bg-secondary);
    border-radius: 0 4px 4px 0;
  }

  .message-content :global(blockquote p:first-of-type) { margin-top: 0; }
  .message-content :global(blockquote p:last-of-type)  { margin-bottom: 0; }

  .message-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5em 0;
  }

  .message-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875em;
  }

  .message-content :global(th),
  .message-content :global(td) {
    border: 1px solid var(--border);
    padding: 0.5em 1em;
    text-align: left;
  }

  .message-content :global(th) {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .message-content :global(td) {
    color: #c5c4c2;
  }

  .message-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    margin-top: 0.75em;
    margin-bottom: 0.75em;
  }
</style>
